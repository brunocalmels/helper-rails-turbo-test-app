<div class="container">
  <h1>Page 2</h1>
  <div class="button-container">
    <%= link_to "Go to Homepage", root_path, class: "giant-square-button" %>
  </div>
</div>

<style>
  body {
    margin: 0;
    padding: 0;
  }
  
  .container {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 100vh;
    font-family: Arial, sans-serif;
    background-color: #f0f8f0;
  }
  
  h1 {
    margin-bottom: 50px;
    font-size: 3rem;
    color: #333;
    text-align: center;
  }
  
  .giant-square-button {
    width: 200px;
    height: 200px;
    background-color: #28a745;
    color: white;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 1.5rem;
    font-weight: bold;
    text-decoration: none;
    border-radius: 15px;
    transition: all 0.3s ease;
    box-shadow: 0 8px 15px rgba(40, 167, 69, 0.3);
    text-align: center;
  }
  
  .giant-square-button:hover {
    background-color: #1e7e34;
    transform: translateY(-2px);
    box-shadow: 0 12px 20px rgba(40, 167, 69, 0.4);
  }
</style>
